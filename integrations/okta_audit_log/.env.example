# Okta
# Your Okta tenant domain, no scheme. e.g. hillspire.okta.com
OKTA_DOMAIN=
# Okta API token (Security -> API -> Tokens). Needs read access to system log.
OKTA_API_TOKEN=
# Optional override for the admin URL used in Confluence links.
# Defaults to https://<tenant>-admin.okta.com.
OKTA_ADMIN_URL=

# Confluence Cloud
# Base wiki URL, e.g. https://hillspire.atlassian.net/wiki
CONFLUENCE_BASE_URL=
# Atlassian account email that owns the API token.
CONFLUENCE_EMAIL=
# Atlassian API token: https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_API_TOKEN=
# Space key the audit log lives in, e.g. SYSENG
CONFLUENCE_SPACE_KEY=
# Page ID of the empty parent page that will become the index page.
# Find it in the page URL: .../pages/<this-number>/...
CONFLUENCE_INDEX_PAGE_ID=
